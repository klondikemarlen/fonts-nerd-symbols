#!/usr/bin/env bash
set -euo pipefail

version="${1:-3.4.0}"
package="fonts-nerd-symbols"
release="v${version}"
base_url="https://github.com/ryanoasis/nerd-fonts/releases/download/${release}"
repo_root="$(cd "$(dirname "${BASH_SOURCE[0]}")/../.." && pwd)"
workdir="$(mktemp -d)"
trap 'rm -rf "${workdir}"' EXIT

zip="${workdir}/NerdFontsSymbolsOnly.zip"
checksums="${workdir}/SHA-256.txt"
srcdir="${repo_root}/build/${package}-${version}"
orig="${repo_root}/build/${package}_${version}.orig.tar.xz"

rm -rf "${srcdir}"
mkdir -p "${srcdir}/upstream" "${repo_root}/build"

wget -q -O "${zip}" "${base_url}/NerdFontsSymbolsOnly.zip"
wget -q -O "${checksums}" "${base_url}/SHA-256.txt"
(
  cd "${workdir}"
  grep 'NerdFontsSymbolsOnly.zip$' SHA-256.txt | sha256sum -c -
)

unzip -q "${zip}" -d "${srcdir}/upstream"
rm -f "${srcdir}/upstream"/*.md "${srcdir}/upstream"/LICENSE
cp -a "${repo_root}/debian" "${srcdir}/debian"

# The orig tarball carries upstream content only; debian/ is supplied separately.
# Keep this reproducible across Debian revisions: Launchpad rejects changed orig tarballs.
tar --sort=name --owner=0 --group=0 --numeric-owner --mtime="@0" \
  --exclude="${package}-${version}/debian" \
  -C "${repo_root}/build" -cJf "${orig}" "${package}-${version}"

echo "Prepared ${srcdir}"
echo "Prepared ${orig}"
echo "Build with: cd ${srcdir} && debuild -us -uc"
