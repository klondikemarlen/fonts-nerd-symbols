#!/usr/bin/env bash
set -euo pipefail

version="${1:-3.4.0+dfsg}"
mode="${2:-dfsg}"
if [ "$#" -gt 2 ]; then
  echo "usage: $0 [VERSION [dfsg|full]]" >&2
  exit 2
fi
upstream_version="${version%%+dfsg*}"
case "${mode}" in
  dfsg|full)
    ;;
  *)
    echo "usage: $0 [VERSION [dfsg|full]]" >&2
    exit 2
    ;;
esac
if [ "${mode}" = full ] && [[ "${version}" == *+dfsg* ]]; then
  echo "full mode requires a non-+dfsg version" >&2
  exit 2
fi
if [ "${mode}" = dfsg ] && [[ "${version}" != *+dfsg* ]]; then
  echo "dfsg mode requires a +dfsg version" >&2
  exit 2
fi
package="fonts-nerd-symbols"
release="v${upstream_version}"
upstream_repo="https://github.com/ryanoasis/nerd-fonts.git"
repo_root="$(cd "$(dirname "${BASH_SOURCE[0]}")/../.." && pwd)"
workdir="$(mktemp -d)"
trap 'rm -rf "${workdir}"' EXIT

checkout="${workdir}/nerd-fonts"
srcdir="${repo_root}/build/${package}-${version}"
orig="${repo_root}/build/${package}_${version}.orig.tar.xz"

rm -rf "${srcdir}"
mkdir -p "${srcdir}/upstream-src" "${repo_root}/build"

git clone --depth 1 --branch "${release}" --filter=blob:none --sparse "${upstream_repo}" "${checkout}"
git -C "${checkout}" sparse-checkout set --no-cone \
  /font-patcher \
  /LICENSE \
  /license-audit.md \
  /10-nerd-font-symbols.conf \
  /bin/scripts/generate-original-source.py \
  /bin/scripts/lib \
  /src/glyphs \
  /src/svgs \
  /src/unpatched-fonts/NerdFontsSymbolsOnly

cp -a \
  "${checkout}/font-patcher" \
  "${checkout}/LICENSE" \
  "${checkout}/license-audit.md" \
  "${checkout}/10-nerd-font-symbols.conf" \
  "${checkout}/bin" \
  "${checkout}/src" \
  "${srcdir}/upstream-src/"

if [ "${mode}" = dfsg ]; then
  rm -f "${srcdir}/upstream-src/src/glyphs/font-logos.ttf"
  rm -f "${srcdir}/upstream-src/bin/scripts/lib/i_logos.sh"
fi

cp -a "${repo_root}/debian" "${srcdir}/debian"


# The orig tarball carries upstream content only; debian/ is supplied separately.
# Keep this reproducible across Debian revisions: Launchpad rejects changed orig tarballs.
tar --sort=name --owner=0 --group=0 --numeric-owner --mtime="@0" \
  --exclude="${package}-${version}/debian" \
  -C "${repo_root}/build" -cJf "${orig}" "${package}-${version}"

echo "Prepared ${srcdir} (${mode})"
echo "Prepared ${orig}"
echo "Build with: cd ${srcdir} && NERD_SYMBOLS_BUILD=${mode} debuild -us -uc"
