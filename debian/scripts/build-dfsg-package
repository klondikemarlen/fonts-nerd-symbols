#!/usr/bin/env bash
set -euo pipefail

package="fonts-nerd-symbols"
repo_root="$(cd "$(dirname "${BASH_SOURCE[0]}")/../.." && pwd)"
current_version="$(cd "${repo_root}" && dpkg-parsechangelog -S Version)"
current_distribution="$(cd "${repo_root}" && dpkg-parsechangelog -S Distribution)"
source_version="${1:-${current_version}}"
distribution="${2:-${current_distribution}}"
if [ "$#" -gt 2 ]; then
  echo "usage: $0 [SOURCE_VERSION [DISTRIBUTION]]" >&2
  exit 2
fi
source_tree_version="${source_version%-*}"

if [[ "${source_tree_version}" != *+dfsg* ]]; then
  echo "DFSG package version must include +dfsg" >&2
  exit 2
fi

srcdir="${repo_root}/build/${package}-${source_tree_version}"
"${repo_root}/debian/scripts/prepare-upstream" "${source_tree_version}" dfsg

if [ "${source_version}" != "${current_version}" ] || [ "${distribution}" != "${current_distribution}" ]; then
  changelog="${srcdir}/debian/changelog"
  tmp="$(mktemp)"
  trap 'rm -f "${tmp}"' EXIT
  {
    printf '%s (%s) %s; urgency=medium\n\n' "${package}" "${source_version}" "${distribution}"
    printf '  * Build DFSG Symbols Nerd Font package from source inputs.\n\n'
    printf ' -- Marlen Brunner <klondikemarlen@gmail.com>  %s\n\n' "$(date -R)"
    cat "${changelog}"
  } >"${tmp}"
  mv "${tmp}" "${changelog}"
fi

cd "${srcdir}"
NERD_SYMBOLS_BUILD=dfsg debuild -us -uc
